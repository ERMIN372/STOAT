# Copy to .env.local and fill in. Never commit real secrets.

# --- Sanity (catalog / CMS) ---
# projectId + dataset are public (shipped to the browser for the Studio & reads).
NEXT_PUBLIC_SANITY_PROJECT_ID=20rmo551
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Server-only token with WRITE access (Editor). Needed for the seed script, the
# payment webhook (stock) and order storage. Keep it secret.
SANITY_API_TOKEN=
# Orders are stored in a SEPARATE, PRIVATE dataset so customer data is never
# public. Create it in the Sanity dashboard (visibility: Private), default name:
SANITY_ORDERS_DATASET=orders

# --- ЮKassa (payments) ---
# Server-only. Get these from the ЮKassa merchant dashboard (Настройки → Магазин).
# Leave empty to run the store in "приём заявок" mode (no online payment).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Send a fiscal receipt (54-ФЗ) with each payment. Turn on once your ЮKassa
# account is set up for receipts. vat_code 1 = без НДС (самозанятый / УСН).
YOOKASSA_SEND_RECEIPT=false
YOOKASSA_VAT_CODE=1
# Public site URL used to build the payment return_url and webhook (e.g.
# https://stoat-ermin372s-projects.vercel.app or your custom domain).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Delivery engine (general rules; safe to tweak) ---
# Order preparation window shown everywhere (business days). The customer's
# final ETA = preparation + carrier delivery.
DELIVERY_PREP_MIN_DAYS=3
DELIVERY_PREP_MAX_DAYS=7
# Flat packing/handling surcharge (₽) added on top of every carrier tariff, then
# the total is rounded UP to DELIVERY_PRICE_ROUNDING.
DELIVERY_PACKAGING_SURCHARGE=70
DELIVERY_PRICE_ROUNDING=10
# Pickup ("Самовывоз после готовности"). Off by default — enable only once you
# have a real pickup address. NEXT_PUBLIC_* so the storefront can read it.
NEXT_PUBLIC_PICKUP_ENABLED=false
NEXT_PUBLIC_PICKUP_ADDRESS=

# --- СДЭК (CDEK) ---
# Get API credentials in the CDEK account: Настройки → Интеграция → API.
# Leave empty to hide CDEK options (checkout still works).
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
# test = sandbox (api.edu.cdek.ru), production = live (api.cdek.ru).
CDEK_MODE=production
# Sender location. Prefer the numeric CDEK city code (e.g. Москва = 44); the
# city/postal are fallbacks. Find codes via /location/cities or CDEK docs.
CDEK_FROM_CITY_CODE=
CDEK_FROM_CITY=Москва
CDEK_FROM_POSTAL_CODE=
# Sender's shipment point / warehouse code — needed to CREATE shipments.
CDEK_FROM_SHIPMENT_POINT=
# Tariff codes: 136 = склад-склад (до ПВЗ), 137 = склад-дверь (курьер).
CDEK_TARIFF_PVZ=136
CDEK_TARIFF_COURIER=137

# --- Почта России (Otpravka API) ---
# Get the AccessToken in the Otpravka cabinet (otpravka.pochta.ru) and use your
# pochta.ru login/password for X-User-Authorization. Leave empty to hide Почта.
RUSSIAN_POST_TOKEN=
RUSSIAN_POST_LOGIN=
RUSSIAN_POST_PASSWORD=
# Alternative to login/password: a pre-encoded base64(login:password).
RUSSIAN_POST_AUTH_KEY=
# Sender index + city (index is REQUIRED for tariff calculation).
RUSSIAN_POST_FROM_POSTAL_CODE=
RUSSIAN_POST_FROM_CITY=Москва
# Default mail type/category (POSTAL_PARCEL + ORDINARY are sane defaults).
RUSSIAN_POST_MAIL_TYPE=POSTAL_PARCEL
RUSSIAN_POST_MAIL_CATEGORY=ORDINARY

# --- Owner notifications: Telegram ---
# Orders are posted to the @stoat_shop channel by default — just set the bot
# token and make the bot an admin of the channel (with "Post messages").
# Override the target with TELEGRAM_CHAT_ID (numeric id or @channelusername).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Admin panel (/admin) ---
# Password to access the orders admin. Required to open /admin at all.
ADMIN_PASSWORD=

# --- Customer email (optional, transactional) ---
# Two providers are supported. If nothing is configured, orders still work —
# emails are just skipped and logged (a warning), never blocking the order.
#
# EMAIL_PROVIDER selects the provider explicitly:
#   resend → use Resend (needs RESEND_API_KEY)
#   smtp   → use SMTP / Nodemailer (needs SMTP_HOST, SMTP_USER, SMTP_PASS)
# If EMAIL_PROVIDER is empty, we auto-pick: Resend if RESEND_API_KEY is set,
# otherwise SMTP if SMTP_* are set, otherwise email is skipped.
EMAIL_PROVIDER=

# "From" address used by both providers. For Yandex SMTP it MUST equal SMTP_USER.
EMAIL_FROM="STOAT <stoat.ermins@yandex.ru>"

# Resend: API key + a verified sending domain (required to deliver to arbitrary
# recipients). Left empty here — not used until a domain is set up.
RESEND_API_KEY=

# SMTP (free MVP via plain Yandex Mail — no domain / Yandex 360 needed).
# SMTP_PASS is an *app password* created in Yandex ID, not your login password.
SMTP_HOST=smtp.yandex.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=stoat.ermins@yandex.ru
SMTP_PASS=
