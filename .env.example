# Copy to .env.local and fill in. Never commit real secrets.

# --- Sanity (catalog / CMS) ---
# projectId + dataset are public (shipped to the browser for the Studio & reads).
NEXT_PUBLIC_SANITY_PROJECT_ID=20rmo551
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Server-only token with WRITE access (Editor). Needed for the seed script and,
# later, the payment webhook that decrements stock. Keep it secret.
SANITY_API_TOKEN=

# --- ЮKassa (payments) — Phase 2, not active yet ---
# Server-only. Get these from the ЮKassa merchant dashboard.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Public site URL used to build the payment return_url (e.g. https://stoat.store)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Order notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
